NODE_ENV=production
HOST=0.0.0.0
PORT=49030

# Required. Keep the real value in server/.env or systemd environment.
AQN_API_KEY=

# The AQN endpoint may change; keep it configurable.
AQN_API_URL=https://api.quantumnumbers.anu.edu.au
AQN_TIMEOUT_MS=15000

# Comma-separated origins. Use * only during local testing.
CORS_ORIGINS=*
